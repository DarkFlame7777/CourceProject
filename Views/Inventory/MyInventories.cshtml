@model IEnumerable<MyProject.Models.Entities.Inventory>

@{
    ViewData["Title"] = "My inventories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My inventories</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create inventory
    </a>
</div>

@if (Model.Any())
{
    <form asp-action="Delete" method="post" id="deleteForm">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>
                            <input type="checkbox" id="selectAll" class="form-check-input" />
                        </th>
                        <th>Title</th>
                        <th>Date create</th>
                        <th>Number of fields</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inventory in Model)
                    {
                        var fields = System.Text.Json.JsonSerializer.Deserialize<List<object>>(inventory.FieldsJson) ?? new();

                        <tr>
                            <td>
                                <input type="checkbox" name="selectedIds" value="@inventory.Id" class="form-check-input row-checkbox" />
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@inventory.Id">@inventory.Title</a>
                            </td>
                            <td>@inventory.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>@fields.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <button type="button" class="btn btn-outline-danger" id="deleteSelectedBtn" disabled>
                <i class="bi bi-trash"></i> Delete
            </button>

            <a asp-action="Edit" class="btn btn-outline-secondary" id="editSelectedBtn" disabled>
                <i class="bi bi-pencil"></i> Edit
            </a>
        </div>
    </form>
}
else
{
    <div class="alert alert-info">
        You don't have any inventory yet. <a asp-action="Create">Create the first one!</a>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('selectAll').addEventListener('change', function(e) {
            document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = e.target.checked);
            updateButtons();
        });

        document.querySelectorAll('.row-checkbox').forEach(cb => {
            cb.addEventListener('change', updateButtons);
        });

        function updateButtons() {
            const checked = document.querySelectorAll('.row-checkbox:checked');
            const deleteBtn = document.getElementById('deleteSelectedBtn');
            const editBtn = document.getElementById('editSelectedBtn');

            if (checked.length > 0) {
                deleteBtn.disabled = false;

                if (checked.length === 1) {
                    editBtn.disabled = false;
                    editBtn.href = '@Url.Action("Edit")' + '/' + checked[0].value;
                } else {
                    editBtn.disabled = true;
                    editBtn.href = '#';
                }
            } else {
                deleteBtn.disabled = true;
                editBtn.disabled = true;
                editBtn.href = '#';
            }
        }

        document.getElementById('deleteSelectedBtn').addEventListener('click', function() {
            if (confirm('Delete selected inventories?')) {
                document.getElementById('deleteForm').submit();
            }
        });
    </script>
}